class Product:
    def __init__(self, price):
        self._price = price if price > 0 else 0

    @property
    def price(self):
        return self._price

    @price.setter
    def price(self, value):
        if value > 0:
            self._price = value
        else:
            print("Giá phải lớn hơn 0!")
    def __str__(self):
        return f"Product Price: {self._price}"
sp = Product(100)
sp.price = 150 
sp.price = -50
print(sp)
