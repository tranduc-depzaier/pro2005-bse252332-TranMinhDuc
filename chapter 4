  def tinh_trung_binh:
    if not bang_diem:
        return 0
    tong_diem = sum(bang_diem.values())
    so_sv = len(bang_diem)
    return tong_diem / so_sv
sinh_vien = {"An": 8.5, "Bình": 7.0, "Chi": 9.0}
print(f"Điểm trung bình: {tinh_trung_binh(sinh_vien)}")
