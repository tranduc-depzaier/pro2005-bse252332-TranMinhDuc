  arr = [float(x) for x in input("Nhập danh sách số thực: ").split()]
for i in range(1, len(arr)):
    key = arr[i]
    j = i - 1
    while j >= 0 and key > arr[j]:
        arr[j + 1] = arr[j]
        j -= 1
    arr[j + 1] = key
print("Danh sách giảm dần:", arr)
