  arr = [int(x) for x in input("Nhập danh sách số nguyên: ").split()]
count = 0
n = len(arr)
for i in range(n):
    for j in range(0, n - i - 1):
        if arr[j] > arr[j + 1]:
            arr[j], arr[j + 1] = arr[j + 1], arr[j]
            count += 1
print("Mảng sau khi sắp xếp:", arr)
print("Số lần hoán đổi:", count)
